# ============================================================
#  HAIBAZO Book Review — Root .gitignore
#  Covers: Python (FastAPI backend) + Node.js (React frontend)
# ============================================================

# ──────────────────────────────────────────────────────────────
#  OS / Editor
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ──────────────────────────────────────────────────────────────
#  Environment / Secrets
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────────────────────
#  Python / Backend
# ──────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.pytest_cache/
coverage.xml

# Type checkers
.mypy_cache/
.pytype/
.pyre/
.ruff_cache/

# ──────────────────────────────────────────────────────────────
#  Node.js / Frontend
# ──────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
